---
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.DEV ? '/favicon-dev.svg' : '/favicon.svg'} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <slot />
  </body>
</html>
