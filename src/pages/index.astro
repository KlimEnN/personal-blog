---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Головна" description="Персональний блог Андрія Клименка про продукти, аналітику та технології.">
  <main style="max-width: var(--container-max); margin: 0 auto; padding: 80px 32px 64px;">
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.02em; color: var(--color-ink); margin-bottom: 20px;">
      Привіт, це мій блог
    </h1>
    <p style="font-size: 18px; color: var(--color-secondary); max-width: 480px; line-height: 1.6;">
      Ділюся досвідом про побудову цифрових сервісів, аналітику, AI та рішення, що створюють цінність.
    </p>
  </main>
</Layout>
