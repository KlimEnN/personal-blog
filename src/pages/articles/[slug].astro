---
import Layout from '../../layouts/Layout.astro'
import { getPublishedArticles, getArticleBySlug } from '../../lib/notion'

export function getStaticPaths() {
  const articles = getPublishedArticles()
  return articles.map(article => ({
    params: { slug: article.slug },
  }))
}

const { slug } = Astro.params
const article = getArticleBySlug(slug)

if (!article) return Astro.redirect('/articles')
---

<Layout title={article.title}>
  <main style="max-width: 680px; margin: 0 auto; padding: 48px 32px 80px;">
    <a href="/articles" style="font-size: 13px; color: var(--color-muted); text-decoration: none; display: inline-block; margin-bottom: 40px; transition: color 0.15s;" onmouseover="this.style.color='var(--color-ink)'" onmouseout="this.style.color='var(--color-muted)'">← Всі статті</a>

    <h1 style="font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 500; line-height: 1.2; letter-spacing: -0.01em; color: var(--color-ink); margin: 0 0 16px;">
      {article.title}
    </h1>

    <time style="font-size: 13px; color: var(--color-muted); display: block; margin-bottom: 48px;">
      {new Date(article.createdAt).toLocaleDateString('uk-UA', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>

    <article class="prose prose-gray max-w-none" set:html={article.content} />
  </main>
</Layout>
