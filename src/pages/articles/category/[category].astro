---
import Layout from '../../../layouts/Layout.astro'
import ArticleCard from '../../../components/ArticleCard.astro'
import { getPublishedArticles } from '../../../lib/notion'
import { getCategories, getCategorySlug, getCategoryDescription } from '../../../lib/categories'

export function getStaticPaths() {
  const articles = getPublishedArticles()
  const categories = getCategories(articles)

  return categories.map(({ slug, label }) => ({
    params: { category: slug },
    props: { categoryLabel: label },
  }))
}

const { category } = Astro.params
const { categoryLabel } = Astro.props

const allArticles = getPublishedArticles()
const articles = allArticles.filter(a => getCategorySlug(a) === category)
const allCategories = getCategories(allArticles)

const description = getCategoryDescription(category)
const pageTitle = `${categoryLabel} — Статті`
const ogDescription = `${description} Блог Андрія Клименка.`
---

<Layout title={pageTitle} description={ogDescription}>
  <main class="articles-main">
    <div class="articles-header">
      <h1 class="articles-title">Статті</h1>
      <p class="articles-subtitle">Ділюся досвідом про продукти, аналітику та технології</p>
    </div>

    <!-- Фільтри -->
    <div class="filters">
      <a href="/articles/" class="filter-chip">Всі</a>
      {allCategories.map(({ slug, label }) => (
        <a
          href={`/articles/category/${slug}/`}
          class={`filter-chip ${slug === category ? 'active' : ''}`}
        >
          {label}
        </a>
      ))}
    </div>

    {articles.length === 0 ? (
      <p style="color: var(--color-muted);">Статей у цій категорії поки немає.</p>
    ) : (
      <div class="articles-grid">
        {articles.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    )}
  </main>
</Layout>

<style>
  .articles-main {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 64px 32px 96px;
  }

  .articles-header {
    margin-bottom: 32px;
  }

  .articles-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: var(--color-ink);
  }

  .articles-subtitle {
    font-size: 16px;
    color: var(--color-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    color: var(--color-secondary);
    transition: all 0.15s;
  }

  .filter-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-chip.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .articles-main {
      padding: 40px 20px 72px;
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
