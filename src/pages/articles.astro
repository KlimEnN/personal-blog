---
import Layout from '../layouts/Layout.astro'
import { getPublishedArticles } from '../lib/notion'

const articles = getPublishedArticles()
---

<Layout title="Статті" description="Всі статті Андрія Клименка про продукти, аналітику та технології.">
  <main style="max-width: var(--container-max); margin: 0 auto; padding: 64px 32px;">
    <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 48px;">Статті</h1>

    {articles.length === 0 ? (
      <p style="color: var(--color-muted);">Статей поки немає.</p>
    ) : (
      <ul style="display: flex; flex-direction: column; gap: 0; list-style: none; padding: 0; margin: 0;">
        {articles.map(article => (
          <li style="border-bottom: 1px solid var(--color-border);">
            <a href={`/articles/${article.slug}`} style="display: block; padding: 24px 0; text-decoration: none; transition: opacity 0.15s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              <h2 style="font-size: 18px; font-weight: 600; color: var(--color-ink); margin: 0 0 8px;">{article.title}</h2>
              <time style="font-size: 13px; color: var(--color-muted);">
                {new Date(article.createdAt).toLocaleDateString('uk-UA', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>
