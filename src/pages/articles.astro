---
import Layout from '../layouts/Layout.astro'
import ArticleCard from '../components/ArticleCard.astro'
import { getPublishedArticles } from '../lib/notion'

const articles = getPublishedArticles()
---

<Layout title="Статті" description="Всі статті Андрія Клименка про продукти, аналітику та технології.">
  <main style="max-width: var(--container-max); margin: 0 auto; padding: 64px 32px 80px;">
    <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; letter-spacing: -0.02em; margin: 0 0 48px;">Статті</h1>

    {articles.length === 0 ? (
      <p style="color: var(--color-muted);">Статей поки немає.</p>
    ) : (
      <div class="articles-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
        {articles.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    )}
  </main>
</Layout>

<style>
  @media (max-width: 900px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 580px) {
    .articles-grid { grid-template-columns: 1fr !important; }
    main { padding: 40px 20px 64px !important; }
  }
</style>
