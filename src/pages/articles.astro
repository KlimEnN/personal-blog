---
import Layout from '../layouts/Layout.astro'
import ArticleCard from '../components/ArticleCard.astro'
import { getPublishedArticles } from '../lib/notion'

const articles = getPublishedArticles()
---

<Layout title="Статті" description="Всі статті Андрія Клименка про продукти, аналітику та технології.">
  <main class="articles-main">
    <div class="articles-header">
      <h1 class="articles-title">Статті</h1>
      <p class="articles-subtitle">Ділюся досвідом про продукти, аналітику та технології</p>
    </div>

    {articles.length === 0 ? (
      <p style="color: var(--color-muted);">Статей поки немає.</p>
    ) : (
      <div class="articles-grid">
        {articles.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    )}
  </main>
</Layout>

<style>
  .articles-main {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 64px 32px 96px;
  }

  .articles-header {
    margin-bottom: 48px;
  }

  .articles-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: var(--color-ink);
  }

  .articles-subtitle {
    font-size: 16px;
    color: var(--color-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .articles-main {
      padding: 40px 20px 72px;
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
