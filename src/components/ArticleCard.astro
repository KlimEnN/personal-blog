---
import type { Article } from '../lib/notion'

interface Props {
  article: Article
}

const { article } = Astro.props

const date = new Date(article.createdAt).toLocaleDateString('uk-UA', {
  year: 'numeric', month: 'long', day: 'numeric'
})
---

<a
  href={`/articles/${article.slug}`}
  style="display: block; background: var(--color-card); border-radius: var(--radius-card); padding: 28px; box-shadow: var(--shadow-card); text-decoration: none; transition: box-shadow 0.2s, transform 0.2s;"
  onmouseover="this.style.boxShadow='var(--shadow-hover)'; this.style.transform='translateY(-2px)'"
  onmouseout="this.style.boxShadow='var(--shadow-card)'; this.style.transform='translateY(0)'"
>
  {article.category && (
    <span style="font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-accent);">
      {article.category}
    </span>
  )}

  <h3 style={`font-size: 17px; font-weight: 700; color: var(--color-ink); line-height: 1.3; margin: ${article.category ? '8px' : '0'} 0 10px;`}>
    {article.title}
  </h3>

  {article.description && (
    <p style="font-size: 14px; color: var(--color-secondary); line-height: 1.5; margin: 0 0 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
      {article.description}
    </p>
  )}

  <div style="display: flex; align-items: center; gap: 12px; margin-top: auto;">
    <time style="font-size: 12px; color: var(--color-muted);">{date}</time>
    {article.readTime && (
      <>
        <span style="color: var(--color-border); font-size: 12px;">·</span>
        <span style="font-size: 12px; color: var(--color-muted);">{article.readTime} хв</span>
      </>
    )}
  </div>
</a>
