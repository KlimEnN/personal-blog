---
import { SITE } from '../config/site'

const navLinks = [
  { href: '/', label: 'Головна' },
  { href: '/about', label: 'Про мене' },
  { href: '/articles', label: 'Статті' },
]

const currentPath = Astro.url.pathname
---

<header style="height: var(--nav-height); border-bottom: 1px solid var(--color-border); background: var(--color-bg); position: sticky; top: 0; z-index: 50; backdrop-filter: blur(8px);">
  <nav style="max-width: var(--container-max); margin: 0 auto; padding: 0 32px; height: 100%; display: flex; align-items: center; justify-content: space-between;">

    <a href="/" style="font-family: var(--font-main); font-weight: 700; font-size: 15px; color: var(--color-ink); text-decoration: none; letter-spacing: -0.01em;">
      {SITE.author}
    </a>

    <!-- Desktop nav -->
    <ul class="desktop-nav" style="display: flex; gap: 32px; list-style: none; margin: 0; padding: 0;">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            style={`font-family: var(--font-main); font-size: 14px; font-weight: 500; text-decoration: none; transition: color 0.15s; color: ${currentPath === link.href ? 'var(--color-accent)' : 'var(--color-secondary)'};`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Burger button (mobile) -->
    <button
      id="burger"
      aria-label="Меню"
      class="burger-btn"
      style="display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px;"
    >
      <span style="display: block; width: 22px; height: 2px; background: var(--color-ink); border-radius: 2px; transition: transform 0.2s;"></span>
      <span style="display: block; width: 22px; height: 2px; background: var(--color-ink); border-radius: 2px; transition: opacity 0.2s;"></span>
      <span style="display: block; width: 22px; height: 2px; background: var(--color-ink); border-radius: 2px; transition: transform 0.2s;"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    style="display: none; position: fixed; top: var(--nav-height); left: 0; right: 0; background: var(--color-bg); border-bottom: 1px solid var(--color-border); padding: 16px 24px 24px; z-index: 49;"
  >
    <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px;">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            style={`display: block; padding: 12px 0; font-size: 16px; font-weight: 500; text-decoration: none; border-bottom: 1px solid var(--color-border); color: ${currentPath === link.href ? 'var(--color-accent)' : 'var(--color-ink)'};`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  @media (max-width: 640px) {
    .desktop-nav { display: none !important; }
    .burger-btn { display: flex !important; }
  }
</style>

<script>
  const burger = document.getElementById('burger')
  const menu = document.getElementById('mobile-menu')
  burger?.addEventListener('click', () => {
    const open = menu?.style.display === 'block'
    if (menu) menu.style.display = open ? 'none' : 'block'
  })
</script>
