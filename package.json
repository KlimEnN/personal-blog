{
  "name": "personal-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env scripts/ensure-data.mjs && astro dev",
    "build": "node --env-file-if-exists=.env scripts/fetch-notion.mjs && astro check && astro build",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@notionhq/client": "^5.22.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.7",
    "marked": "^18.0.5",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true
